# مع Docker (docker compose up -d) — المنفذ 5433 لتجنب تعارض PostgreSQL المحلي
DATABASE_URL="postgresql://beeplay:beeplay@localhost:5433/beeplay"

# بدون Docker — PostgreSQL محلي على 5432 (أنشئ المستخدم عبر scripts/create-beeplay-user.sql)
# DATABASE_URL="postgresql://beeplay:beeplay@localhost:5432/beeplay"

# أو استخدم حساب postgres الخاص بك:
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/beeplay"
JWT_SECRET="change-me-in-production"
REFRESH_SECRET="change-me-refresh"
CORS_ORIGIN="http://localhost:3000"
WEB_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"
API_PORT=4000
