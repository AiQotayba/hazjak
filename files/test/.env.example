# Environment Variables for Hazjak
# Copy this file to .env and fill in your values

# Application Configuration
NODE_ENV=development
PORT=3000

# API Configuration (for future backend)
API_BASE_URL=https://api.hazjak.com
API_TIMEOUT=10000

# Database Configuration (for future backend)
# DATABASE_URL=postgresql://username:password@localhost:5432/hazjak

# External Services
# WHATSAPP_API_KEY=your_whatsapp_api_key
# PAYMENT_GATEWAY_KEY=your_payment_key

# Security
# JWT_SECRET=your_jwt_secret_key
# SESSION_SECRET=your_session_secret

# Email Configuration (for future features)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Logging
LOG_LEVEL=info

# Performance
CACHE_TTL=3600