{
  "name": "@hazjak/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "node scripts/with-root-env.mjs generate && node scripts/build-vercel.mjs",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=../../.env dist/server.js",
    "generate": "node scripts/with-root-env.mjs generate",
    "push": "node scripts/with-root-env.mjs db push",
    "migrate": "node scripts/with-root-env.mjs migrate dev",
    "seed": "node scripts/run-seed.mjs",
    "studio": "node scripts/with-root-env.mjs studio",
    "db:test": "tsx --env-file=../../.env scripts/test-db.ts"
  },
  "dependencies": {
    "@hazjak/config": "workspace:*",
    "@hazjak/constants": "workspace:*",
    "@hazjak/types": "workspace:*",
    "@hazjak/utils": "workspace:*",
    "@hazjak/validation": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.15.32",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.25.5",
    "prisma": "^7.8.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
