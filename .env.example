# MySQL (مطابق لـ apps/api/prisma/schema.prisma)
# DATABASE_URL="mysql://hazjak:hazjak@localhost:3306/hazjak"
DATABASE_URL="postgresql://hazjak:hazjak@localhost:5433/hazjak"
DATABASE_PROVIDER="postgresql"
JWT_SECRET="change-me-in-production"
REFRESH_SECRET="change-me-refresh"
# Comma-separated — يُدمج تلقائياً مع WEB_URL و ADMIN_URL + كل *.vercel.app
CORS_ORIGIN="https://hazjak.vercel.app"
CORS_ALLOWED_ORIGINS="https://hazjak.vercel.app,https://beeplay.vercel.app,https://admin-hazjak.vercel.app,http://localhost:3000,http://localhost:3001"
WEB_URL="https://hazjak.vercel.app"
ADMIN_URL="https://admin-hazjak.vercel.app"
API_PORT=4000
NODE_ENV=production
# خلف nginx/reverse proxy — أو يُفعَّل تلقائياً خارج development
TRUST_PROXY=1

# SMTP (اختياري — بدونها تُطبع الرسائل في سجل الخادم)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hazjak.sy
