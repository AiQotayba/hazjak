{
  "name": "hazjak",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test:e2e": "pnpm --filter @hazjak/web test:e2e",
    "db:generate": "pnpm --filter @hazjak/api generate",
    "db:push": "pnpm --filter @hazjak/api push",
    "db:migrate": "pnpm --filter @hazjak/api migrate",
    "db:seed": "pnpm --filter @hazjak/api seed",
    "db:studio": "pnpm --filter @hazjak/api studio",
    "db:test": "pnpm --filter @hazjak/api db:test",
    "env:check": "pnpm --filter @hazjak/api env:check",
    "email:test": "pnpm --filter @hazjak/api email:test",
    "db:setup": "docker compose up -d && pnpm db:push && pnpm db:seed",
    "db:setup:local": "powershell -ExecutionPolicy Bypass -File scripts/ensure-hazjak-db.ps1",
    "db:setup:local:legacy": "powershell -ExecutionPolicy Bypass -File scripts/setup-local-postgres.ps1",
    "deploy:api": "ssh api-beeplay@45.132.241.51 \"bash -ic 'cd ~/htdocs/api-beeplay.sy-calculator.com/beeplay && git pull && cd apps/api && pnpm run build && pm2 restart beeplay-api --update-env'\"",
    "deploy:web": "vercel --prod --project hazjak",
    "deploy:admin": "vercel --prod --project admin-hazjak"
  },
  "devDependencies": {
    "dotenv": "^16.5.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
